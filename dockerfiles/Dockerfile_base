# -----------------------------
# VAPER 2.0
# -----------------------------
FROM python:3.11-slim-bullseye

ARG VAPER_VER="2.0"
ARG SOURMASH_VER="4.9.2"

LABEL org.opencontainers.image.base.name="python:3.11-slim-bullseye" \
      org.opencontainers.image.title="VAPER" \
      org.opencontainers.image.version="${VAPER_VER}" \
      org.opencontainers.image.description="VAPER pipeline dependencies" \
      org.opencontainers.image.url="https://github.com/DOH-JDJ0303/vaper" \
      org.opencontainers.image.licenses="Apache-2.0" \
      org.opencontainers.image.authors="Jared Johnson <jared.johnson@doh.wa.gov>"

ENV DEBIAN_FRONTEND=noninteractive \
    LC_ALL=C.UTF-8 \
    LANG=C.UTF-8 \
    PIP_NO_CACHE_DIR=1 \
    PATH="/root/edirect:${PATH}"

# Install all dependencies in one layer
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential \
      libatlas-base-dev \
      gfortran \
      libfreetype6-dev \
      libpng-dev \
      git \
      curl \
      wget \
      ca-certificates \
      procps \
      mafft \
      minimap2 \
      pigz \
    && python -m pip install --upgrade pip \
    && python -m pip install \
      "matplotlib>=3.3" \
      scikit-learn \
      sourmash==${SOURMASH_VER} \
    && curl -fsSL https://ftp.ncbi.nlm.nih.gov/entrez/entrezdirect/install-edirect.sh | bash \
    && curl -fsSL -o /usr/local/bin/datasets https://ftp.ncbi.nlm.nih.gov/pub/datasets/command-line/v2/linux-amd64/datasets \
    && curl -fsSL -o /usr/local/bin/dataformat https://ftp.ncbi.nlm.nih.gov/pub/datasets/command-line/v2/linux-amd64/dataformat \
    && chmod +x /usr/local/bin/datasets /usr/local/bin/dataformat \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /data

# Verify installations
RUN sourmash --version && \
    datasets --version && \
    mafft --version && \
    minimap2 --version